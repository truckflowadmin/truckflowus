# ─────────────────────────────────────────────────
# TruckFlowUS Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────

# PostgreSQL connection string
# Local dev: postgresql://truckflow:truckflow@localhost:5432/truckflow?schema=public
# Production: use your Neon/Supabase/Railway connection string
DATABASE_URL="postgresql://truckflow:truckflow@localhost:5432/truckflow?schema=public"

# Auth — generate a strong secret with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# The public base URL of this app (used in emails, SMS links, sitemap)
# Local: http://localhost:3000
# Production: https://truckflowus.com
APP_URL="http://localhost:3000"

# Textbelt SMS
# Get a paid key from https://textbelt.com/ for production.
# Use "textbelt" (free, 1/day) or "textbelt_test" (free, no delivery) for dev.
TEXTBELT_KEY="textbelt_test"
TEXTBELT_WEBHOOK_SECRET=""

# Google Maps — address autocomplete on job forms
# Get an API key from https://console.cloud.google.com/apis/credentials
# Enable "Places API" and "Maps JavaScript API"
# Leave blank to disable autocomplete (fields still work as plain text)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Anthropic API — required for AI ticket scanning
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# SMTP — for sending emails (invoices, password resets, driver resets)
# If SMTP_HOST is blank, emails are logged to console instead of sent
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="dispatch@truckflowus.com"
